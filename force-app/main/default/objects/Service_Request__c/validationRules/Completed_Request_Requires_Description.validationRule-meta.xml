<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Completed_Request_Requires_Description</fullName>
    <active>true</active>
    <description>Requires a description when the service request is completed.</description>
    <errorConditionFormula>AND(ISPICKVAL(Status__c, &quot;Completed&quot;), ISBLANK(Description__c))</errorConditionFormula>
    <errorDisplayField>Description__c</errorDisplayField>
    <errorMessage>A completed request must contain a description.</errorMessage>
</ValidationRule>
