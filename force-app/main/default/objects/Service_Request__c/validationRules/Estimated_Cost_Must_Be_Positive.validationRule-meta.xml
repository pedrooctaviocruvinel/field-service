<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Estimated_Cost_Must_Be_Positive</fullName>
    <active>true</active>
    <description>Prevents negative estimated costs.</description>
    <errorConditionFormula>Estimated_Cost__c &lt; 0</errorConditionFormula>
    <errorDisplayField>Estimated_Cost__c</errorDisplayField>
    <errorMessage>Estimated Cost must be greater than or equal to zero.</errorMessage>
</ValidationRule>
